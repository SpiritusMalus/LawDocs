# Telegram bot for receiving lead notifications.
# Create a bot via @BotFather, get the token, then start a chat with it
# and grab your chat id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Full site URL used in sitemap and OG tags. Defaults to https://lawdocs.ru if empty.
NEXT_PUBLIC_SITE_URL=https://lawdocs.ru

# Yandex.Metrika counter id (numeric, e.g. 99999999). Leave empty to disable.
NEXT_PUBLIC_YM_COUNTER_ID=
