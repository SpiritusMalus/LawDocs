# App
APP_ENV=development
SECRET_KEY=   # openssl rand -hex 32
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
# В Docker используйте hostname "postgres" (имя сервиса в docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://lawdocs:CHANGE_ME@postgres:5432/lawdocs

# GigaChat (основной LLM)
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@lawdocs.ru

# Яндекс Object Storage (S3)
# Создать bucket: https://console.yandex.cloud/
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=lawdocs-documents
S3_REGION=ru-central1

# Frontend URL
FRONTEND_URL=https://lawdocs.ru

# Telegram-алерты (опционально)
# Создать бота: @BotFather → /newbot → скопировать TOKEN
# CHAT_ID: отправить /start боту, открыть https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
