# App
APP_ENV=development
SECRET_KEY=   # openssl rand -hex 32
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
# В Docker используйте hostname "postgres" (имя сервиса в docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://lawdocs:CHANGE_ME@postgres:5432/lawdocs

# GigaChat (основной LLM)
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# Claude / Anthropic (fallback LLM)
ANTHROPIC_API_KEY=

# ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@lawdocs.ru

# Хранилище документов (локальный диск, папка создаётся автоматически)
DOCUMENTS_DIR=/var/lawdocs/documents

# Frontend URL
FRONTEND_URL=https://lawdocs.ru
