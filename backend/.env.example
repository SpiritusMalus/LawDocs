# App
APP_ENV=development
SECRET_KEY=   # openssl rand -hex 32
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://lawdocs:password@localhost:5432/lawdocs

# GigaChat (основной LLM)
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# Claude / Anthropic (fallback LLM)
ANTHROPIC_API_KEY=

# ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@lawdocs.ru

# S3 (Selectel или Timeweb)
S3_ENDPOINT=
S3_BUCKET=lawdocs-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Frontend URL
FRONTEND_URL=https://lawdocs.ru
